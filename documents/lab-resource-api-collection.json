			"item": [
				{
					"name": "Register User",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"researcher@lab.com\",\n    \"password\": \"password123\",\n    \"role\": \"user\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": "{{baseUrl}}/auth/register"
					}
				},
				{
					"name": "Login User",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var jsonData = pm.response.json();",
									"if (jsonData.userData && jsonData.userData.token) {",
									"    pm.collectionVariables.set(\"token\", jsonData.userData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
